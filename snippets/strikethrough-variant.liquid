{% doc %}
  Renders a strikethrough line SVG for unavailable product options.

  @param {object} product_option - The product option object. Renders the strikethrough when product_option.available is false.
{% enddoc %}

{% unless product_option.available %}
  <svg
    viewBox="0 0 100 46"
    preserveAspectRatio="xMidYMid slice"
    class="variant-option__strikethrough"
    aria-hidden="true"
  >
    {% # 25deg %}
    <line x1="100" y1="0" x2="0" y2="46" vector-effect="non-scaling-stroke" />
    {% # duplicate line for motion overlay %}
    <line x1="100" y1="0" x2="0" y2="46" vector-effect="non-scaling-stroke" />
  </svg>
{% endunless %}
