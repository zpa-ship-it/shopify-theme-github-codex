  endif

  if variant_hover_background_has_alpha
    assign effective_variant_hover_text = settings.palette_variant_text
  else
    assign effective_variant_hover_text = variant_hover_contrast
  endif

  if settings.palette_variant_border == settings.palette_variant_background
    assign effective_variant_hover_border = effective_variant_hover_background
  else
