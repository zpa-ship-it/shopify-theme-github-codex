    endcapture
  endif
%}

{% style %}
  /* Palette colors */
  :root {
    --color-background: {{ settings.page_background_color }};
    --color-background-rgb: {{ settings.page_background_color.rgb }};
    --color-foreground: {{ settings.page_text_color }};
    --color-foreground-rgb: {{ settings.page_text_color.rgb }};
    --color-border: {{ settings.page_text_color }};
    --color-border-rgb: {{ settings.page_text_color.rgb }};
    --palette-lightest: {{ palette_lightest }};
    --palette-lightest-rgb: {{ palette_lightest.rgb }};
    --palette-darkest: {{ palette_darkest }};
    --palette-darkest-rgb: {{ palette_darkest.rgb }};
    {% render 'brightness-opacities', background: settings.page_background_color %}

    --color-primary-button-text: rgb({{ settings.palette_primary_button_text.rgba }});
    --color-primary-button-background: rgb({{ settings.palette_primary_button_background.rgba }});
    --color-primary-button-border: rgb({{ settings.palette_primary_button_border.rgba }});
    --color-primary-button-focus-outline: rgb({{ effective_primary_button_focus_outline.rgb }});
    --color-primary-button-hover-text: rgb({{ effective_primary_button_hover_text.rgba }});
    --color-primary-button-hover-background: {{ effective_primary_button_hover_background }};
    --color-primary-button-hover-border: {{ effective_primary_button_hover_border }};

    --color-secondary-button-text: rgb({{ settings.palette_secondary_button_text.rgba }});
    --color-secondary-button-background: rgb({{ settings.palette_secondary_button_background.rgba }});
    --color-secondary-button-border: rgb({{ settings.palette_secondary_button_border.rgba }});
    --color-secondary-button-hover-text: rgb({{ effective_secondary_button_hover_text.rgba }});
    --color-secondary-button-hover-background: {{ effective_secondary_button_hover_background }};
    --color-secondary-button-hover-border: {{ effective_secondary_button_hover_border }};

    --color-input-background: rgb({{ settings.palette_input_background.rgba }});
    --color-input-text: rgb({{ settings.palette_input_text.rgba }});
    --color-input-text-rgb: {{ settings.palette_input_text.rgb }};
    --color-input-border: rgb({{ settings.palette_input_border.rgba }});

    --color-variant-background: rgb({{ settings.palette_variant_background.rgba }});
    --color-variant-border: rgb({{ settings.palette_variant_border.rgba }});
    --color-variant-text: rgb({{ settings.palette_variant_text.rgba }});
    --color-variant-text-rgb: {{ settings.palette_variant_text.rgb }};
    --color-variant-hover-background: {{ effective_variant_hover_background }};
    --color-variant-hover-text: rgb({{ effective_variant_hover_text.rgba }});
    --color-variant-hover-border: {{ effective_variant_hover_border }};

    --color-selected-variant-background: rgb({{ settings.palette_selected_variant_background.rgba }});
    --color-selected-variant-border: rgb({{ settings.palette_selected_variant_border.rgba }});
    --color-selected-variant-text: rgb({{ settings.palette_selected_variant_text.rgba }});
    --color-selected-variant-hover-background: {{ effective_selected_variant_hover_background }};
    --color-selected-variant-hover-text: rgb({{ effective_selected_variant_hover_text.rgba }});
    --color-selected-variant-hover-border: {{ effective_selected_variant_hover_border }};

    --input-disabled-background-color: rgb(var(--color-foreground-rgb) / var(--opacity-10));
    --input-disabled-border-color: rgb(var(--color-foreground-rgb) / var(--opacity-5-15));
    --input-disabled-text-color: rgb(var(--color-foreground-rgb) / var(--opacity-50));
    --color-foreground-muted: rgb(var(--color-rgb, var(--color-foreground-rgb)) / var(--opacity-muted-text));
    --color-foreground-subdued: rgb(var(--color-rgb, var(--color-foreground-rgb)) / var(--opacity-subdued-text));
    --color-drawer-shadow-rgb: {{ settings.drawer_shadow_color.rgb }};
    --color-popover-shadow-rgb: {{ settings.popover_shadow_color.rgb }};

    /* Shadows */
    {% if settings.drawer_drop_shadow %}
      --shadow-drawer: 0px 4px 20px rgb(var(--color-drawer-shadow-rgb) / var(--opacity-15));
    {% endif %}
    {% if settings.popover_drop_shadow %}
      --shadow-blur: 20px;
      --shadow-popover: 0px 4px 20px rgb(var(--color-popover-shadow-rgb) / var(--opacity-15));
    {% endif %}
  }

  body {
    color: var(--color-foreground);
    background-color: var(--color-background);
  }
{% endstyle %}
