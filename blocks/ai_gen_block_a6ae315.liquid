      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "skip_button_position_right",
      "label": "Position droite",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "skip_button_radius",
      "label": "Rayon de bordure",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "color",
      "id": "skip_button_bg",
      "label": "Couleur de fond",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "skip_button_color",
      "label": "Couleur du texte",
      "default": "#000000"
    },
    {
      "type": "range",
