      "min": 0,
      "max": 2,
      "step": 0.1,
      "unit": "s",
      "default": 0.5
    },
    {
      "type": "header",
      "content": "Bouton de fermeture"
    },
    {
      "type": "range",
      "id": "close_button_size",
      "label": "Taille",
      "min": 30,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 50
    },
    {
      "type": "range",
      "id": "close_button_position_top",
      "label": "Position haut",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "close_button_position_right",
      "label": "Position droite",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "color",
      "id": "close_button_bg",
      "label": "Couleur de fond",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "close_button_color",
      "label": "Couleur de l'icône",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "close_button_opacity",
      "label": "Opacité",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 80
    },
    {
      "type": "header",
      "content": "Bouton passer"
    },
    {
      "type": "checkbox",
      "id": "show_skip_button",
      "label": "Afficher le bouton passer",
      "default": true
    },
    {
      "type": "text",
      "id": "skip_button_text",
      "label": "Texte du bouton",
      "default": "Passer"
    },
    {
      "type": "range",
      "id": "skip_button_position_bottom",
