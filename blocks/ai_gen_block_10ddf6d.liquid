{% doc %}
  @prompt
    cinematic intro
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-cinematic-intro-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    height: {{ block.settings.height }}vh;
    overflow: hidden;
    background-color: {{ block.settings.background_color }};
  }

  .ai-cinematic-intro-video-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    min-width: 100%;
    min-height: 100%;
    width: auto;
    height: auto;
    object-fit: cover;
    opacity: {{ block.settings.video_opacity | divided_by: 100.0 }};
  }

  .ai-cinematic-intro-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: {{ block.settings.image_opacity | divided_by: 100.0 }};
  }

  .ai-cinematic-intro-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #1a1a1a;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-cinematic-intro-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
    opacity: 0.3;
  }

  .ai-cinematic-intro-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      {{ block.settings.overlay_direction }},
      {{ block.settings.overlay_color_start }},
      {{ block.settings.overlay_color_end }}
    );
    opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
  }

  .ai-cinematic-intro-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: {{ block.settings.text_alignment }};
    justify-content: {{ block.settings.vertical_alignment }};
    height: 100%;
    padding: 40px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-cinematic-intro-title-{{ ai_gen_id }} {
    color: {{ block.settings.title_color }};
    font-size: {{ block.settings.title_size }}px;
    margin: 0 0 20px;
    max-width: 800px;
    line-height: 1.2;
  }

  .ai-cinematic-intro-subtitle-{{ ai_gen_id }} {
    color: {{ block.settings.subtitle_color }};
    font-size: {{ block.settings.subtitle_size }}px;
    margin: 0 0 30px;
    max-width: 600px;
    line-height: 1.5;
  }

  .ai-cinematic-intro-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 16px 40px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    transition: all 0.3s ease;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border }};
  }

  .ai-cinematic-intro-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text }};
    transform: translateY(-2px);
  }

  .ai-cinematic-intro-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 24px;
    background-color: rgba(0, 0, 0, 0.6);
    color: #ffffff;
    font-size: 14px;
    border-radius: 8px;
    z-index: 3;
  }

  @media screen and (max-width: 749px) {
    .ai-cinematic-intro-{{ ai_gen_id }} {
      height: {{ block.settings.mobile_height }}vh;
    }

    .ai-cinematic-intro-content-{{ ai_gen_id }} {
      padding: 20px;
    }

    .ai-cinematic-intro-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.6);
    }

    .ai-cinematic-intro-subtitle-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subtitle_size }}px * 0.8);
    }

    .ai-cinematic-intro-button-{{ ai_gen_id }} {
      padding: 12px 28px;
      font-size: calc({{ block.settings.button_text_size }}px * 0.9);
    }
  }
{% endstyle %}

<cinematic-intro-{{ ai_gen_id }}
  class="ai-cinematic-intro-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.video_url != blank %}
    <video
      class="ai-cinematic-intro-video-{{ ai_gen_id }}"
      autoplay
      muted
      loop
      playsinline
    >
      <source src="{{ block.settings.video_url }}" type="video/mp4">
    </video>
  {% elsif block.settings.background_image %}
    <img
      src="{{ block.settings.background_image | image_url: width: 2000 }}"
      alt="{{ block.settings.background_image.alt | escape }}"
      loading="lazy"
      width="{{ block.settings.background_image.width }}"
      height="{{ block.settings.background_image.height }}"
      class="ai-cinematic-intro-image-{{ ai_gen_id }}"
    >
  {% else %}
    <div class="ai-cinematic-intro-placeholder-{{ ai_gen_id }}">
      {{ 'hero-apparel-1' | placeholder_svg_tag }}
    </div>
  {% endif %}

  <div class="ai-cinematic-intro-overlay-{{ ai_gen_id }}"></div>

  <div class="ai-cinematic-intro-content-{{ ai_gen_id }}">
    {% if block.settings.title != blank %}
      <h1 class="ai-cinematic-intro-title-{{ ai_gen_id }}">{{ block.settings.title }}</h1>
    {% endif %}

    {% if block.settings.subtitle != blank %}
      <div class="ai-cinematic-intro-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</div>
    {% endif %}

    {% if block.settings.button_label != blank and block.settings.button_link != blank %}
      <a
        href="{{ block.settings.button_link }}"
        class="ai-cinematic-intro-button-{{ ai_gen_id }}"
      >
        {{ block.settings.button_label }}
      </a>
    {% endif %}
  </div>

  {% if block.settings.video_url == blank and block.settings.background_image == blank %}
    <div class="ai-cinematic-intro-empty-state-{{ ai_gen_id }}">
      Next, add a video or background image
    </div>
  {% endif %}
</cinematic-intro-{{ ai_gen_id }}>

<script>
  (function() {
    class CinematicIntro{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.video = this.querySelector('.ai-cinematic-intro-video-{{ ai_gen_id }}');
        if (this.video) {
          this.ensureVideoPlays();
        }
      }

      ensureVideoPlays() {
        const playPromise = this.video.play();
        if (playPromise !== undefined) {
          playPromise.catch(() => {
            this.video.muted = true;
            this.video.play();
          });
        }
      }
    }

    customElements.define('cinematic-intro-{{ ai_gen_id }}', CinematicIntro{{ ai_gen_id }});
  })();
</script>

